JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=30d
FCM_ENABLED=true
# Path to Firebase service account JSON
FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
# Optional: raw JSON or base64-encoded JSON string
# FCM_SERVICE_ACCOUNT_JSON=

# SMTP (Zoho) - for password reset emails
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-zoho-app-password
SMTP_FROM=Time Command <noreply@yourdomain.com>
# The public URL of the web app (used in reset links and OAuth callbacks)
APP_URL=https://yourdomain.com

# OneDrive sync (optional)
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add redirect URI: https://yourdomain.com/api/onedrive/callback
# Add API permission: Microsoft Graph → Delegated → Files.ReadWrite.AppFolder, offline_access
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
